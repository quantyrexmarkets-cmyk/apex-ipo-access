/* ===================================== */
/* === ★★★ FINAL NAV + LOGO ★★★ === */
/* ===================================== */
.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(12px);
  position: sticky;
  top: 0;
  z-index: 100;
}
.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  color: #fff;
}
.logo-x {
  height: 34px;
  width: auto;
  display: block;
  filter: drop-shadow(0 0 6px rgba(255, 40, 40, 0.5));
  transition: all 0.3s ease;
}
.logo:hover .logo-x {
  filter: drop-shadow(0 0 12px rgba(255, 60, 60, 0.8));
  transform: scale(1.05);
}
.logo-text {
  font-family: 'Plus Jakarta Sans', 'Inter', system-ui, sans-serif;
  font-weight: 600;
  font-size: 17px;
  letter-spacing: -0.3px;
  color: #fff;
  line-height: 1;
  white-space: nowrap;
}
.logo-accent {
  color: #1E90FF;
  margin-left: 4px;
}
.nav-right {
  display: flex;
  align-items: center;
  gap: 12px;
}
@media (min-width: 768px) {
  .nav { padding: 12px 32px; }
  .logo-x { height: 40px; }
  .logo-text { font-size: 19px; }
}
@media (max-width: 380px) {
  .logo-x { height: 28px; }
  .logo-text { font-size: 14px; }
}

/* ============================== */
/* === EMERGENCY NAV RESTORE === */
/* ============================== */
.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(30, 144, 255, 0.1);
  position: sticky;
  top: 0;
  z-index: 1000;
  width: 100%;
}
.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  color: #fff;
  flex-shrink: 0;
}
.logo-x {
  height: 32px;
  width: auto;
  display: block;
  filter: drop-shadow(0 0 6px rgba(255, 40, 40, 0.5));
  transition: all 0.3s ease;
}
.logo:hover .logo-x {
  filter: drop-shadow(0 0 12px rgba(255, 60, 60, 0.8));
  transform: scale(1.05);
}
.logo-text {
  font-family: 'Inter', 'Poppins', system-ui, sans-serif;
  font-weight: 600;
  font-size: 17px;
  letter-spacing: -0.3px;
  color: #fff;
  line-height: 1;
  white-space: nowrap;
}
.logo-accent {
  color: #1E90FF;
  margin-left: 4px;
  font-weight: 600;
}
.nav-right {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}

/* Restore body padding so content isn't behind sticky nav */
body { padding-top: 0; }

@media (min-width: 768px) {
  .nav { padding: 14px 32px; }
  .logo-x { height: 38px; }
  .logo-text { font-size: 19px; }
}
@media (max-width: 380px) {
  .logo-x { height: 26px; }
  .logo-text { font-size: 14px; }
}
