@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700&display=swap');

*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#000;
  --blue:#1E90FF;
  --blue2:#0066FF;
  --blue-glow:#00AEEF;
  --text:#E8EEF7;
  --text2:#CBD5E1;
  --muted:#7A8699;
}

html,body{
  background:#000;
  color:var(--text);
  font-family:'Inter',sans-serif;
  overflow-x:hidden;
  scroll-behavior:smooth;
  font-size:15px;
  line-height:1.65;
  -webkit-font-smoothing:antialiased;
}

.btn-signin{
  color:#fff;
  text-decoration:none;
  font-size:.9rem;
  font-weight:500;
  padding:.5rem .8rem;
}

.hamburger{
  width:36px;height:36px;
  background:transparent;
  border:1px solid rgba(255,255,255,.15);
  border-radius:8px;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  gap:5px;
  cursor:pointer;
  padding:0;
}
.hamburger span{width:18px;height:1.5px;background:#fff;border-radius:2px;transition:.3s}
.hamburger.active span:nth-child(1){transform:translateY(6.5px) rotate(45deg)}
.hamburger.active span:nth-child(2){opacity:0}
.hamburger.active span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg)}

.hero-image{max-width:1100px;margin:-1rem auto 0;padding:0 1.25rem}
.hero-image-wrap{
  position:relative;
  border-radius:20px;
  overflow:hidden;
  border:1px solid rgba(30,144,255,.2);
  box-shadow:0 30px 80px rgba(0,0,0,.6),0 0 60px rgba(255,255,255,.04);
}
.hero-image-wrap img{width:100%;display:block;filter:contrast(1.05) brightness(.92)}
.hero-image-wrap::before{
  content:"";position:absolute;top:0;left:0;right:0;height:30%;
  background:linear-gradient(180deg,rgba(0,0,0,.95),transparent);z-index:2;
}
.hero-image-wrap::after{
  content:"";position:absolute;bottom:0;left:0;right:0;height:60%;
  background:linear-gradient(0deg,rgba(0,0,0,.95) 10%,transparent);z-index:2;
}
.hero-image-caption{position:absolute;bottom:0;left:0;right:0;padding:1.8rem 1.5rem 1.4rem;z-index:3;text-align:center}
.caption-divider{width:40px;height:1px;background:linear-gradient(90deg,transparent,var(--blue),transparent);margin:0 auto 1rem}
.caption-title{font-family:'Inter',sans-serif;font-size:1rem;font-weight:600;color:#fff;margin-bottom:.3rem}
.caption-sub{font-size:.74rem;color:var(--muted);letter-spacing:1.2px;text-transform:uppercase}

