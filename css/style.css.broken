/* Subtle pulse glow */
@keyframes logoGlow {
  0%, 100% {
    filter: 
      drop-shadow(0 0 6px rgba(255, 30, 30, 0.5))
      drop-shadow(0 0 14px rgba(255, 50, 50, 0.25));
  }
  50% {
    filter: 
      drop-shadow(0 0 10px rgba(255, 40, 40, 0.8))
      drop-shadow(0 0 20px rgba(255, 60, 60, 0.4));
  }
}

